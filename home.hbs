{{#*inline "body"}}
<main class="gh-main">
    {{> partials/components/header layout="wide" background="image" primary=@root.custom.primary_header secondary=@root.custom.secondary_header}}
    {{> partials/podcast-services}}
    <section class="gh-archive gh-outer">
        <div class="gh-archive-inner gh-inner">
            <header class="gh-archive-header">
                <h1 class="gh-archive-title">Latest episodes</h1>
            </header>
        </div>
    </section>
    {{> partials/components/list layout="simple" count="3" showExcerpt=true showPublishedAt=true}}
    {{#match pagination.pages ">" 1}}
        <div class="gh-more gh-outer">
            <div class="gh-inner">
                <a href="/page/2">All episodes →</a>
            </div>
        </div>
    {{/match}}
    {{> partials/components/cta title=@root.custom.email_signup_text}}
</main>
{{/inline}}
{{> default}}