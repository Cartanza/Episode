<div class="gh-podcast-service-list gh-outer">
    {{#if @root.custom.apple_podcasts_link}}
        <a href="{{@root.custom.apple_podcasts_link}}" target="_blank" rel="noopener noreferrer">
            {{> partials/icons/apple}}
            <span>Listen on</span>
            <span>Apple Podcasts</span>
        </a>
    {{/if}}
    {{#if @root.custom.spotify_link}}
        <a href="{{@root.custom.spotify_link}}" target="_blank" rel="noopener noreferrer">
            {{> partials/icons/spotify}}
            <span>Listen on</span>
            <span>Spotify</span>
        </a>
    {{/if}}
    {{#if @root.custom.youtube_music_link}}
        <a href="{{@root.custom.youtube_music_link}}" target="_blank" rel="noopener noreferrer">
            {{> partials/icons/youtube}}
            <span>Listen on</span>
            <span>YouTube Music</span>
        </a>
    {{/if}}
</div>